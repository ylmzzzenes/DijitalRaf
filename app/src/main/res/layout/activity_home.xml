<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.home.HomeActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="@dimen/bottom_nav_height"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bannerEmailVerification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/grid_2"
            android:layout_marginTop="@dimen/grid_2"
            android:visibility="gone"
            app:cardBackgroundColor="@color/primary_alpha_12"
            app:cardCornerRadius="@dimen/corner_medium"
            app:cardElevation="@dimen/elevation_card"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp">

            <TextView
                android:id="@+id/tvBannerEmailVerification"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawablePadding="@dimen/grid_2"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/grid_2"
                android:paddingVertical="@dimen/grid_2"
                android:text="@string/email_verification_banner_message"
                android:textAppearance="@style/TextAppearance.DijitalRaf.Body"
                android:textColor="@color/text_primary"
                app:drawableStartCompat="@drawable/ic_menu_book_24"
                app:drawableTint="@color/primary" />
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/mainViewPager"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <FrameLayout
                android:id="@+id/kitapEkleOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/background"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/surface"
        app:elevation="@dimen/elevation_card_raised"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemPaddingTop="6dp"
        app:itemTextAppearanceActive="@style/TextAppearance.DijitalRaf.BottomNavActive"
        app:itemTextAppearanceInactive="@style/TextAppearance.DijitalRaf.BottomNavInactive"
        app:itemTextColor="@color/bottom_nav_color"
        app:labelVisibilityMode="selected"
        app:menu="@menu/bottom_nav_menu" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddBook"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/grid_2"
        android:layout_marginBottom="@dimen/fab_margin_above_bottom_nav"
        android:contentDescription="@string/nav_add_book"
        app:layout_anchor="@id/bottomNav"
        app:layout_anchorGravity="top|end"
        app:backgroundTint="?attr/colorPrimaryContainer"
        app:srcCompat="@drawable/ic_add_24"
        app:tint="?attr/colorOnPrimaryContainer" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
