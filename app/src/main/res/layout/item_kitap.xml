<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/grid_1"
    android:layout_marginEnd="@dimen/grid_1"
    android:layout_marginBottom="@dimen/grid_2"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="18dp"
    app:cardElevation="5dp"
    app:rippleColor="@color/primary_alpha_24"
    app:strokeColor="@color/secondary_alpha_40"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="132dp"
        android:padding="14dp">

        <ImageView
            android:id="@+id/ivCover"
            android:layout_width="82dp"
            android:layout_height="112dp"
            android:background="@drawable/bg_book_cover"
            android:contentDescription="@null"
            android:elevation="2dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_add_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/ic_add_24" />

        <TextView
            android:id="@+id/tvKitapAdi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Title"
            android:textSize="19sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/ivFavorite"
            app:layout_constraintStart_toEndOf="@+id/ivCover"
            app:layout_constraintTop_toTopOf="@+id/ivCover"
            tools:text="Kürk Mantolu Madonna" />

        <TextView
            android:id="@+id/tvYazar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Subtitle"
            android:textSize="15sp"
            app:layout_constraintEnd_toStartOf="@+id/ivFavorite"
            app:layout_constraintStart_toEndOf="@+id/ivCover"
            app:layout_constraintTop_toBottomOf="@+id/tvKitapAdi"
            tools:text="Sabahattin Ali" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTur"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/primary_dark"
            android:textStyle="bold"
            app:chipBackgroundColor="@color/primary_alpha_12"
            app:chipMinHeight="34dp"
            app:chipStrokeColor="@color/secondary_alpha_40"
            app:chipStrokeWidth="1dp"
            app:layout_constraintEnd_toStartOf="@+id/ivFavorite"
            app:layout_constraintStart_toEndOf="@+id/ivCover"
            app:layout_constraintTop_toBottomOf="@+id/tvYazar"
            tools:text="Fiction" />

        <TextView
            android:id="@+id/tvRating"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Caption"
            android:textColor="@color/text_secondary"
            app:layout_constraintEnd_toStartOf="@+id/ivFavorite"
            app:layout_constraintStart_toEndOf="@+id/ivCover"
            app:layout_constraintTop_toBottomOf="@+id/chipTur"
            tools:text="⭐⭐⭐⭐⭐" />

        <TextView
            android:id="@+id/tvReadDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Caption"
            android:textColor="@color/text_secondary"
            app:layout_constraintEnd_toStartOf="@+id/ivFavorite"
            app:layout_constraintStart_toEndOf="@+id/ivCover"
            app:layout_constraintTop_toBottomOf="@+id/tvRating"
            tools:text="Okundu: 12.04.2026" />

        <ImageButton
            android:id="@+id/ivFavorite"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_favorites"
            android:padding="8dp"
            android:src="@drawable/ic_favorite_border_24"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/ivCover" />

        <ImageButton
            android:id="@+id/ivShare"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="2dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Kitap paylaş"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_share"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ivFavorite" />

        <ImageView
            android:id="@+id/ivReadStatus"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="6dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_done_24"
            app:tint="#2E7D32"
            app:layout_constraintEnd_toEndOf="@+id/ivShare"
            app:layout_constraintTop_toBottomOf="@+id/ivShare"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>