<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.DijitalRaf.Card.Outlined"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/grid_1"
    android:layout_marginEnd="@dimen/grid_1"
    android:layout_marginBottom="@dimen/grid_2"
    app:rippleColor="@color/primary_alpha_24">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="132dp"
        android:padding="@dimen/book_list_item_padding">

        <ImageView
            android:id="@+id/ivCover"
            android:layout_width="@dimen/book_list_cover_width"
            android:layout_height="@dimen/book_list_cover_height"
            android:background="@drawable/bg_book_cover"
            android:contentDescription="@null"
            android:elevation="@dimen/elevation_card"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_add_24"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@drawable/ic_add_24" />

        <TextView
            android:id="@+id/tvKitapAdi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/book_list_text_inset"
            android:layout_marginEnd="@dimen/grid_1"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Title"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/ivFavorite"
            app:layout_constraintStart_toEndOf="@+id/ivCover"
            app:layout_constraintTop_toTopOf="@+id/ivCover"
            tools:text="Kürk Mantolu Madonna" />

        <TextView
            android:id="@+id/tvYazar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/book_list_text_inset"
            android:layout_marginTop="@dimen/grid_1"
            android:layout_marginEnd="@dimen/grid_1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Subtitle"
            app:layout_constraintEnd_toStartOf="@+id/ivFavorite"
            app:layout_constraintStart_toEndOf="@+id/ivCover"
            app:layout_constraintTop_toBottomOf="@+id/tvKitapAdi"
            tools:text="Sabahattin Ali" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTur"
            style="@style/Widget.Material3.Chip.Assist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/book_list_text_inset"
            android:layout_marginTop="@dimen/grid_2"
            android:layout_marginEnd="@dimen/grid_1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/primary_dark"
            android:textStyle="bold"
            app:chipBackgroundColor="@color/primary_alpha_12"
            app:chipMinHeight="@dimen/touch_target_min"
            app:chipStrokeColor="@color/outline_variant"
            app:chipStrokeWidth="1dp"
            app:layout_constraintEnd_toStartOf="@+id/ivFavorite"
            app:layout_constraintStart_toEndOf="@+id/ivCover"
            app:layout_constraintTop_toBottomOf="@+id/tvYazar"
            tools:text="Fiction" />

        <TextView
            android:id="@+id/tvRating"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/book_list_text_inset"
            android:layout_marginTop="@dimen/grid_1"
            android:layout_marginEnd="@dimen/grid_1"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Caption"
            android:textColor="@color/text_secondary"
            app:layout_constraintEnd_toStartOf="@+id/ivFavorite"
            app:layout_constraintStart_toEndOf="@+id/ivCover"
            app:layout_constraintTop_toBottomOf="@+id/chipTur"
            tools:text="⭐⭐⭐⭐⭐" />

        <TextView
            android:id="@+id/tvReadDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/book_list_text_inset"
            android:layout_marginTop="@dimen/grid_1"
            android:layout_marginEnd="@dimen/grid_1"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Caption"
            android:textColor="@color/text_secondary"
            app:layout_constraintEnd_toStartOf="@+id/ivFavorite"
            app:layout_constraintStart_toEndOf="@+id/ivCover"
            app:layout_constraintTop_toBottomOf="@+id/tvRating"
            tools:text="Okundu: 12.04.2026" />

        <ImageButton
            android:id="@+id/ivFavorite"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/nav_favorites"
            android:padding="@dimen/grid_1"
            android:src="@drawable/ic_favorite_border_24"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/ivCover" />

        <ImageButton
            android:id="@+id/ivShare"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:layout_marginTop="@dimen/grid_1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_share_book"
            android:padding="@dimen/grid_1"
            android:src="@android:drawable/ic_menu_share"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ivFavorite" />

        <ImageView
            android:id="@+id/ivReadStatus"
            android:layout_width="@dimen/grid_3"
            android:layout_height="@dimen/grid_3"
            android:layout_marginTop="@dimen/grid_1"
            android:contentDescription="@null"
            android:src="@drawable/ic_done_24"
            app:layout_constraintEnd_toEndOf="@+id/ivShare"
            app:layout_constraintTop_toBottomOf="@+id/ivShare"
            app:tint="@color/success"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
