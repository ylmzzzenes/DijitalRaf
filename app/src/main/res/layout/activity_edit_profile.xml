<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        style="@style/Widget.DijitalRaf.Toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:title="@string/edit_profile_title"
        app:navigationIcon="@drawable/outline_arrow_back_24"
        app:navigationIconTint="@color/primary" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="@dimen/grid_2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/grid_4">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardCornerRadius="@dimen/corner_medium"
                    app:cardElevation="@dimen/elevation_card"
                    app:strokeColor="@color/secondary_alpha_40"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical"
                        android:padding="@dimen/grid_3">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/ivAvatar"
                            android:layout_width="96dp"
                            android:layout_height="96dp"
                            android:background="@color/primary_alpha_12"
                            android:contentDescription="@string/edit_profile_change_photo"
                            android:padding="@dimen/grid_2"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_person_24"
                            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.DijitalRaf.Avatar"
                            app:tint="@color/primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/grid_1"
                            android:text="@string/edit_profile_change_photo"
                            android:textAppearance="@style/TextAppearance.DijitalRaf.Caption"
                            android:textColor="@color/primary" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilFirstName"
                            style="@style/Widget.DijitalRaf.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/grid_3"
                            android:hint="@string/hint_first_name">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etFirstName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName|textCapWords"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilLastName"
                            style="@style/Widget.DijitalRaf.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/grid_2"
                            android:hint="@string/hint_last_name">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLastName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName|textCapWords"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilUsername"
                            style="@style/Widget.DijitalRaf.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/grid_2"
                            android:hint="@string/hint_username">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etUsername"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textVisiblePassword"
                                android:maxLines="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/grid_2"
                            android:labelFor="@id/tvEmailReadOnly"
                            android:text="@string/hint_email"
                            android:textAppearance="@style/TextAppearance.DijitalRaf.Caption"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvEmailReadOnly"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="@color/surface_variant"
                            android:padding="@dimen/grid_2"
                            android:textAppearance="@style/TextAppearance.DijitalRaf.Body"
                            android:textColor="@color/text_secondary"
                            tools:text="user@mail.com" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilBio"
                            style="@style/Widget.DijitalRaf.TextInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/grid_2"
                            android:hint="@string/hint_bio"
                            app:counterEnabled="true"
                            app:counterMaxLength="280">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etBio"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="top"
                                android:inputType="textMultiLine|textCapSentences"
                                android:maxLength="280"
                                android:minLines="3" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSaveProfile"
                            style="@style/Widget.DijitalRaf.Button.Filled"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/grid_3"
                            android:text="@string/action_save_profile" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>

        <ProgressBar
            android:id="@+id/progressOverlay"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>
