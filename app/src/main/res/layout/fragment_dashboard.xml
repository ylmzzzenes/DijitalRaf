<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:padding="@dimen/grid_2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Title"
            tools:text="Hoş geldin, Ayşe" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/grid_3"
            android:text="@string/dashboard_section_read"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Subtitle"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/grid_1"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="@dimen/corner_medium"
            app:cardElevation="@dimen/elevation_card"
            app:strokeColor="@color/secondary_alpha_40"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/grid_2">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvReadBooks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:orientation="horizontal"
                    android:clipToPadding="false"
                    tools:listitem="@layout/item_dashboard_book" />

                <TextView
                    android:id="@+id/tvReadBooksEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dashboard_cover_height"
                    android:gravity="center"
                    android:text="@string/dashboard_row_empty_read"
                    android:textAppearance="@style/TextAppearance.DijitalRaf.Caption"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone"
                    tools:visibility="visible" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/grid_3"
            android:text="@string/dashboard_section_to_read"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Subtitle"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/grid_1"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="@dimen/corner_medium"
            app:cardElevation="@dimen/elevation_card"
            app:strokeColor="@color/secondary_alpha_40"
            app:strokeWidth="1dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/grid_2">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvToReadBooks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:orientation="horizontal"
                    android:clipToPadding="false"
                    tools:listitem="@layout/item_dashboard_book" />

                <TextView
                    android:id="@+id/tvToReadBooksEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dashboard_cover_height"
                    android:gravity="center"
                    android:text="@string/dashboard_row_empty_to_read"
                    android:textAppearance="@style/TextAppearance.DijitalRaf.Caption"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone" />
            </FrameLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/grid_3"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="@dimen/corner_medium"
            app:cardElevation="@dimen/elevation_card"
            app:strokeColor="@color/secondary_alpha_40"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/grid_2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/ai_section_title"
                        android:textAppearance="@style/TextAppearance.DijitalRaf.Subtitle"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAiHistoryLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:contentDescription="@string/cd_ai_history_long_press"
                        android:padding="@dimen/grid_1"
                        android:text="@string/ai_old_recommendations"
                        android:textAppearance="@style/TextAppearance.DijitalRaf.Caption"
                        android:textColor="@color/primary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_2"
                    android:baselineAligned="false"
                    android:gravity="top"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAiRecommend"
                        style="@style/Widget.DijitalRaf.Button.Tonal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_get_recommendation" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/grid_2"
                        android:layout_weight="1"
                        android:minHeight="120dp"
                        app:cardBackgroundColor="@color/background"
                        app:cardCornerRadius="@dimen/corner_small"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/secondary_alpha_40"
                        app:strokeWidth="1dp">

                        <TextView
                            android:id="@+id/tvAiPreview"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="120dp"
                            android:padding="@dimen/grid_2"
                            android:text="@string/ai_preview_placeholder"
                            android:textAppearance="@style/TextAppearance.DijitalRaf.Body"
                            android:textColor="@color/text_secondary" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/grid_3"
            android:layout_marginBottom="@dimen/grid_2"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="@dimen/corner_medium"
            app:cardElevation="@dimen/elevation_card"
            app:strokeColor="@color/secondary_alpha_40"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/grid_2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/ai_chat_section_title"
                        android:textAppearance="@style/TextAppearance.DijitalRaf.Subtitle"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvChatHistoryLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="?attr/selectableItemBackground"
                        android:contentDescription="@string/cd_ai_history_long_press"
                        android:padding="@dimen/grid_1"
                        android:text="@string/ai_chat_old_conversations"
                        android:textAppearance="@style/TextAppearance.DijitalRaf.Caption"
                        android:textColor="@color/primary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_2"
                    android:baselineAligned="false"
                    android:gravity="top"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAiAssistant"
                        style="@style/Widget.DijitalRaf.Button.Tonal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_chat_assistant_button" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/grid_2"
                        android:layout_weight="1"
                        android:minHeight="120dp"
                        app:cardBackgroundColor="@color/background"
                        app:cardCornerRadius="@dimen/corner_small"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/secondary_alpha_40"
                        app:strokeWidth="1dp">

                        <TextView
                            android:id="@+id/tvChatPreview"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:minHeight="120dp"
                            android:padding="@dimen/grid_2"
                            android:text="@string/ai_chat_preview_placeholder"
                            android:textAppearance="@style/TextAppearance.DijitalRaf.Body"
                            android:textColor="@color/text_secondary" />
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
