<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ui.home.BookDetailActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/Widget.DijitalRaf.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:title="@string/book_detail_screen_title" />
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:padding="@dimen/grid_2"
            android:visibility="invisible"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ivCover"
                    android:layout_width="160dp"
                    android:layout_height="220dp"
                    android:layout_gravity="center_horizontal"
                    android:background="@drawable/bg_book_cover"
                    android:contentDescription="@null"
                    android:elevation="2dp"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/ic_menu_book_24" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_3"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.DijitalRaf.Title"
                    android:textStyle="bold"
                    tools:text="Kitap adı" />

                <TextView
                    android:id="@+id/tvAuthor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_1"
                    android:gravity="center"
                    android:textAppearance="@style/TextAppearance.DijitalRaf.Subtitle"
                    android:textColor="@color/text_secondary"
                    tools:text="Yazar" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_3"
                    android:text="@string/book_detail_label_description"
                    android:textAppearance="@style/TextAppearance.DijitalRaf.Subtitle"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_1"
                    android:textAppearance="@style/TextAppearance.DijitalRaf.Body"
                    android:textColor="@color/text_primary"
                    tools:text="Özet metni" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_3"
                    android:text="@string/book_detail_label_pages"
                    android:textAppearance="@style/TextAppearance.DijitalRaf.Subtitle"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPageCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_1"
                    android:textAppearance="@style/TextAppearance.DijitalRaf.Body"
                    android:textColor="@color/text_secondary"
                    tools:text="320 sayfa" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_3"
                    android:text="@string/book_detail_label_published"
                    android:textAppearance="@style/TextAppearance.DijitalRaf.Subtitle"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPublishedDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/grid_1"
                    android:layout_marginBottom="@dimen/grid_3"
                    android:textAppearance="@style/TextAppearance.DijitalRaf.Body"
                    android:textColor="@color/text_secondary"
                    tools:text="2021" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorColor="@color/primary"
            tools:visibility="visible" />
    </FrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
