<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/grid_1"
    app:cardBackgroundColor="@color/card_background"
    app:cardCornerRadius="@dimen/corner_medium"
    app:cardElevation="@dimen/elevation_card"
    app:rippleColor="@color/primary_alpha_24"
    app:strokeColor="@color/secondary_alpha_40"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/grid_2">

        <ImageView
            android:id="@+id/ivCover"
            android:layout_width="@dimen/book_cover_size_grid"
            android:layout_height="@dimen/book_cover_size_grid"
            android:background="@drawable/bg_book_cover"
            android:contentDescription="@null"
            android:padding="@dimen/grid_1"
            android:scaleType="centerInside"
            android:src="@drawable/ic_menu_book_24"
            app:tint="@color/primary" />

        <TextView
            android:id="@+id/tvKitapAdi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/grid_2"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Title"
            android:textSize="16sp"
            tools:text="Başlık" />

        <TextView
            android:id="@+id/tvYazar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/grid_1"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Caption"
            android:textSize="13sp"
            tools:text="Yazar" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipTur"
            style="@style/Widget.Material3.Chip.Filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/grid_1"
            android:textColor="@color/primary_dark"
            app:chipBackgroundColor="@color/primary_alpha_12"
            tools:text="Kategori" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
