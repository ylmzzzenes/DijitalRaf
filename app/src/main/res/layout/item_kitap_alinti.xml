<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.DijitalRaf.Card.Flat"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/grid_2"
    app:cardCornerRadius="@dimen/corner_small"
    app:contentPadding="@dimen/grid_2"
    app:strokeColor="@color/outline_variant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvQuoteText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Body"
            android:textColor="@color/text_primary"
            tools:text="“Okumak, yalnız başına yaşamaktır.”" />

        <ImageButton
            android:id="@+id/btnQuoteEdit"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/book_quotes_cd_edit"
            android:padding="@dimen/grid_1"
            app:srcCompat="@drawable/ic_edit_24"
            app:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/btnQuoteDelete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/book_quotes_cd_delete"
            android:padding="@dimen/grid_1"
            app:srcCompat="@drawable/ic_delete_24"
            app:tint="@color/text_secondary" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
