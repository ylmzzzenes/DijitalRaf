<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.DijitalRaf.Card.Flat"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/grid_2"
    app:cardCornerRadius="@dimen/corner_small"
    app:contentPadding="@dimen/grid_2"
    app:strokeColor="@color/outline_variant"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvQuoteText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="@style/TextAppearance.DijitalRaf.Body"
            android:textColor="@color/text_primary"
            tools:text="“Okumak, yalnız başına yaşamaktır.”" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuoteEdit"
            style="@style/Widget.DijitalRaf.Button.Icon.Tonal"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:layout_gravity="top"
            android:contentDescription="@string/book_quotes_cd_edit"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:icon="@drawable/ic_edit_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuoteDelete"
            style="@style/Widget.DijitalRaf.Button.Icon.Tonal"
            android:layout_width="@dimen/touch_target_min"
            android:layout_height="@dimen/touch_target_min"
            android:layout_gravity="top"
            android:contentDescription="@string/book_quotes_cd_delete"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:icon="@drawable/ic_delete_24"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
