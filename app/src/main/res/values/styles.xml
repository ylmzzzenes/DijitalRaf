<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.DijitalRaf.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.DijitalRaf.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.DijitalRaf.Subtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.DijitalRaf.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.DijitalRaf.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.DijitalRaf.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_small</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_small</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_small</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_small</item>
        <item name="boxStrokeColor">@color/text_input_stroke</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <style name="Widget.DijitalRaf.Button.Filled" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/corner_small</item>
        <item name="android:minHeight">@dimen/grid_5</item>
    </style>

    <style name="Widget.DijitalRaf.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/corner_small</item>
        <item name="android:minHeight">@dimen/grid_5</item>
    </style>

    <style name="Widget.DijitalRaf.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/corner_small</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:minHeight">@dimen/grid_5</item>
    </style>

    <style name="Widget.DijitalRaf.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/corner_medium</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <style name="Widget.DijitalRaf.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
    </style>

    <style name="ShapeAppearanceOverlay.DijitalRaf.Avatar" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
