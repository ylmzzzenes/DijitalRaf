<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.DijitalRaf.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.DijitalRaf.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.DijitalRaf.Subtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.DijitalRaf.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.DijitalRaf.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.DijitalRaf.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/corner_small</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_small</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_small</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_small</item>
        <item name="boxStrokeColor">@color/text_input_stroke</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <style name="Widget.DijitalRaf.Button.Filled" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/corner_small</item>
        <item name="android:minHeight">@dimen/grid_5</item>
    </style>

    <style name="Widget.DijitalRaf.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/corner_small</item>
        <item name="android:minHeight">@dimen/grid_5</item>
    </style>

    <style name="Widget.DijitalRaf.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/corner_small</item>
        <item name="strokeColor">@color/primary</item>
        <item name="android:minHeight">@dimen/grid_5</item>
    </style>

    <style name="Widget.DijitalRaf.Button.Icon.Tonal" parent="Widget.Material3.Button.IconButton.Filled.Tonal">
        <item name="iconTint">@color/text_secondary</item>
        <item name="android:minWidth">@dimen/touch_target_min</item>
        <item name="android:minHeight">@dimen/touch_target_min</item>
        <item name="iconPadding">0dp</item>
    </style>

    <style name="Widget.DijitalRaf.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/corner_medium</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.DijitalRaf.Card.Outlined" parent="Widget.DijitalRaf.Card">
        <item name="strokeColor">@color/outline_variant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.DijitalRaf.Card.Flat" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">@dimen/corner_medium</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/surface_variant</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="TextAppearance.DijitalRaf.SectionLabel" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.DijitalRaf.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.DijitalRaf.BottomNavActive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.DijitalRaf.BottomNavInactive" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
    </style>

    <style name="ShapeAppearanceOverlay.DijitalRaf.Avatar" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearanceOverlay.DijitalRaf.DetailBottomBar" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/corner_medium</item>
        <item name="cornerSizeTopRight">@dimen/corner_medium</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.DijitalRaf.HeroCover" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">0dp</item>
        <item name="cornerSizeTopRight">0dp</item>
        <item name="cornerSizeBottomLeft">@dimen/corner_large</item>
        <item name="cornerSizeBottomRight">@dimen/corner_large</item>
    </style>

    <style name="ShapeAppearance.DijitalRaf.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/corner_small</item>
    </style>

    <style name="ShapeAppearance.DijitalRaf.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/corner_medium</item>
    </style>
</resources>
