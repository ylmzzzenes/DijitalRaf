<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.DijitalRaf" parent="Base.Theme.DijitalRaf">
        <!-- Edge-to-edge; light/dark bar icons follow DayNight via @bool/use_light_system_bars -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">@bool/use_light_system_bars</item>
        <item name="android:windowLightNavigationBar">@bool/use_light_system_bars</item>
    </style>
</resources>